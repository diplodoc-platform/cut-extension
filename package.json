{
  "name": "@diplodoc/cut-extension",
  "version": "1.1.3",
  "description": "Cut extension for Diplodoc platform",
  "main": "build/plugin/index.js",
  "types": "build/plugin/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/plugin/index.d.ts",
      "default": "./build/plugin/index.js"
    },
    "./runtime": {
      "types": "./build/runtime/index.d.ts",
      "style": "./build/runtime/index.css",
      "default": "./build/runtime/index.js"
    },
    "./runtime/styles": "./build/runtime/index.css",
    "./runtime/styles.css": "./build/runtime/index.css"
  },
  "homepage": "https://diplodoc.com/",
  "engines": {
    "node": ">=24",
    "npm": ">=11.5.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diplodoc-platform/cut-extension.git"
  },
  "bugs": {
    "url": "https://github.com/diplodoc-platform/diplodoc/issues"
  },
  "author": "",
  "license": "MIT",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "run-p build:*",
    "build:js": "node ./esbuild/build.mjs",
    "build:declarations": "tsc --project tsconfig.publish.json --emitDeclarationOnly --outDir ./build",
    "build:clean": "rm -rf build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build",
    "lint": "lint",
    "lint:fix": "lint fix",
    "pre-commit": "lint-staged",
    "prepare": "husky || true",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@diplodoc/directive": "^0.3.4",
    "@diplodoc/utils": "^2.2.3"
  },
  "devDependencies": {
    "@diplodoc/infra": "2.0.5",
    "@diplodoc/tsconfig": "^1.0.2",
    "@types/markdown-it": "^13.0.9",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^27.0.1",
    "markdown-it": "^13.0.2",
    "npm-run-all": "^4.1.5",
    "ts-dedent": "^2.2.0",
    "typescript": "^5.5.3",
    "vitest": "^3.2.4"
  }
}
